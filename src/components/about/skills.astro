---
import NmapImg from "../../assets/skills/nmap.png";
import WiresharkImg from "../../assets/skills/wireshark.png";
import BurpSuiteImg from "../../assets/skills/burpsuite.svg";
import CapCutImg from "../../assets/skills/capcut.png";
import { translations } from "../../data/translations.js";

const currentLocale = Astro.currentLocale || "en";

const skillCategories = [
  {
    title: translations[currentLocale]["skills.languages"],
    skills: [
      { name: "Python", icon: "python" },
      { name: "PHP",  icon: "php" },
      { name: "C#", icon: "csharp" },
      { name: "JavaScript", icon: "javascript" },
      { name: "TypeScript", icon: "typescript" },
      { name: "SQL", icon: "mysql", variant: "original-wordmark" },
    ],
  },
  {
    title: translations[currentLocale]["skills.frontend"],
    skills: [
      { name: "React", icon: "react" },
      { name: "React Native", icon: "react" },
      { name: "Electron", icon: "electron" },
      { name: "Vue.js", icon: "vuejs"},
      { name: "Tailwind", icon: "tailwindcss"},
    ],
  },
  {
    title: translations[currentLocale]["skills.backend"],
    skills: [
      { name: "AWS", icon: "amazonwebservices", variant: "original-wordmark" },
      { name: "Arduino", icon: "arduino" },
      { name: "Git", icon: "git" },
      { name: "Docker", icon: "docker" },
      { name: "Postman", icon: "postman" },
    ],
  },
  {
    title: translations[currentLocale]["skills.cyber"],
    skills: [
      { name: "Linux", icon: "linux" },
      { name: "Bash", icon: "bash" },
      { name: "Nmap", imgSrc: NmapImg.src },
      { name: "Burp Suite", imgSrc: BurpSuiteImg.src },
      { name: "Wireshark", imgSrc: WiresharkImg.src },
    ],
  },
  {
    title: translations[currentLocale]["skills.creative"],
    skills: [
      { name: "Photoshop", icon: "photoshop" },
      { name: "Canva", icon: "canva" },
      { name: "CapCut", imgSrc: CapCutImg.src },
      { name: "Premiere", icon: "premierepro" },
    ],
  },
];
---

<section class="site-container my-24 md:my-32 mx-auto max-w-6xl px-4 sm:px-6">
  
  <div class="mb-20 flex flex-col items-center text-center">
    <h2 class="text-4xl md:text-5xl font-bold text-white inline-flex flex-col items-center gap-2">
      <span class="relative z-10">{translations[currentLocale]["skills.title"]}</span>
      <span class="h-1.5 w-24 rounded-full bg-gradient-to-r from-[#7836cf] to-[#0debd8] shadow-[0_0_15px_var(--color-brand-purple)]"></span>
    </h2>
    <p class="mt-6 text-zinc-400 max-w-lg text-lg leading-relaxed">
      {translations[currentLocale]["skills.subtitle"]}
    </p>
  </div>

  <div class="space-y-20">
    {skillCategories.map((category) => (
      <div class="relative">
        
        <div class="flex items-center gap-6 mb-10">
          <h3 class="text-2xl md:text-3xl font-bold text-white whitespace-nowrap">
            {category.title}
          </h3>
          <div class="h-px w-full bg-gradient-to-r from-zinc-700 via-zinc-800 to-transparent opacity-50"></div>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6">
          {category.skills.map((skill) => (
            <div class="group relative">
              
              <div class="absolute inset-0 rounded-xl bg-gradient-to-r from-[#7836cf] to-[#0debd8] opacity-0 blur-md transition-opacity duration-300 group-hover:opacity-30"></div>

              <div class="relative flex flex-col items-center justify-center gap-4 rounded-xl border border-zinc-800 bg-[#0a0a0a] p-6 transition-all duration-300 hover:-translate-y-2 hover:border-brand-purple/50 h-full shadow-lg">
                
                <div class={`h-14 w-14 transition-transform duration-300 group-hover:scale-110 flex items-center justify-center ${skill.bg || ''}`}>
                  <img
                    src={skill.imgSrc ? skill.imgSrc : `https://cdn.jsdelivr.net/gh/devicons/devicon/icons/${skill.icon}/${skill.icon}-${skill.variant || 'original'}.svg`}
                    alt={skill.name}
                    class="h-full w-full object-contain drop-shadow-md"
                    loading="lazy"
                  />
                </div>
                
                <span class="text-sm font-semibold text-zinc-400 group-hover:text-white transition-colors text-center">
                  {skill.name}
                </span>

              </div>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>