---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404" description="Error 404 - Page not found" noindex={true}>
  <section
    class="bg-gray-900 min-h-screen flex flex-col items-center justify-center px-6 text-center"
  >
    <h1
      class="text-7xl md:text-8xl font-extrabold text-brand-cyan drop-shadow-[3px_3px_0_var(--color-brand-purple)] mb-6"
    >
      404
    </h1>

    <h2 class="text-2xl md:text-3xl text-white font-semibold mb-6">
      sad
    </h2>

    <p class="text-white/80 max-w-md mx-auto mb-10 font-bold">
      eee
    </p>

    <a
      href="/"
      class="rounded-full bg-brand-cyan px-8 py-3 text-lg font-bold text-[#1d1250] drop-shadow-[3px_3px_0_var(--color-brand-purple)] transition-all duration-150 active:translate-y-0.5 active:drop-shadow-none"
    >
      eeee
    </a>
  </section>
</Layout>
